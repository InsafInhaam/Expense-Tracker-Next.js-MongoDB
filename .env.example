# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/finance?retryWrites=true&w=majority

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Google OAuth (for NextAuth login + Gmail API)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini AI API
GEMINI_API_KEY=your-gemini-api-key

# Token Encryption for Gmail OAuth (32 characters minimum)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=your-32-character-encryption-key!!

# Cron Job Security (for automated Gmail sync)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-random-cron-secret-for-gmail-sync
